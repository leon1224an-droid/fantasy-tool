DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fantasy_tool
NBA_SEASON=2025-26

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string

# Field encryption key for Yahoo tokens at rest — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, tokens are stored as plaintext (not recommended for production).
FIELD_ENCRYPTION_KEY=

# Yahoo Fantasy Sports API credentials (app-level, shared across all users)
# Obtain at: https://developer.yahoo.com/apps/create/
# YAHOO_REFRESH_TOKEN and YAHOO_LEAGUE_ID are now stored per-user in the DB.
# These env vars are only needed for the initial single-user backward-compat mode.
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://your-app.railway.app/auth/yahoo/callback
YAHOO_REFRESH_TOKEN=
YAHOO_LEAGUE_ID=

# Basketball Monster automated download
# Log into basketballmonster.com and check the export URL on the Rankings page.
# Override BBM_DOWNLOAD_URL only if the default doesn't work (see bball_monster_scraper.py).
BBM_EMAIL=
BBM_PASSWORD=
BBM_DOWNLOAD_URL=
